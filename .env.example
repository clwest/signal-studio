# SignalStudio — environment variables

# ── Required ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-key-here
SECRET_KEY=founder-toolkit-shared-secret-2026

# ── Model selection ──────────────────────────────────────────────────────
AI_MODEL=gpt-5-mini

# ── Database ─────────────────────────────────────────────────────────────
# Native: DATABASE_URL=sqlite:///./signalstudio.db
# Docker compose: auto-set to postgresql://signalstudio:signalstudio@signal_studio_postgres:5432/signalstudio
DATABASE_URL=

# ── Postgres credentials (only consumed by docker-compose.yml) ──────────
POSTGRES_DB=signalstudio
POSTGRES_USER=signalstudio
# Local-dev placeholder. Override via .env or a real secret store before any deploy.
POSTGRES_PASSWORD=change-me-in-production

# ── CORS / frontend URL ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8007/api

# ── Brain bridge ─────────────────────────────────────────────────────────
BRAIN_URL=http://host.docker.internal:8000
BRAIN_TOKEN=
BRAIN_CONVERSATION=

# ── Fleet signing (Session 1131 Phase 1) ─────────────────────────────────
# Required for signal-cluster ingest from u-d-b (the GET
# /api/fleet/signals/clusters pull endpoint + the signal.cluster_promoted
# event stream). Without these set, ingest is skipped and seed.py's demo
# data remains the only source of signals.
#
# Mint these via u-d-b:
#   python manage.py provision_fleet_identity --app-slug signal-studio
# The RAW SECRET is shown exactly ONCE — u-d-b stores only SHA256(secret).
FLEET_APP_SLUG=signal-studio
FLEET_KEY_ID=
FLEET_SERVICE_SECRET=
